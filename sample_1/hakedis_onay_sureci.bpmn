<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:spiffworkflow="http://spiffworkflow.org/bpmn/schema/1.0/core"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_insaat_hakedis_sureci"
                  targetNamespace="http://spiffworkflow.org/bpmn/insaat_hakedis_sureci">
  <bpmn:process id="insaat_hakedis_sureci" name="İnşaat Hakediş Kontrol ve Onay Süreci" isExecutable="true">
    <bpmn:documentation>
      Taşeron hakediş taleplerinin saha girişi, İSG kontrolü, PM teknik onayı, finans ön kontrolü ve GM/CFO final onayı ile uçtan uca yürütüldüğü yürütülebilir SpiffWorkflow BPMN süreci.
    </bpmn:documentation>
    <bpmn:startEvent id="StartEvent_Baslangic" name="Başlangıç">
      <bpmn:outgoing>Flow_Start_To_Saha</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_Saha_Hakedis_Girisi" name="Saha Hakediş Girişi">
      <bpmn:documentation>
        Saha mühendisi hakediş dönemini, sözleşme bilgisini, gerçekleşme oranını, talep tutarını ve zorunlu destek dosyalarını girer.
      </bpmn:documentation>
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="formJsonSchemaFilename" value="hakedis_giris.json" />
        </spiffworkflow:properties>
        <spiffworkflow:instructionsForEndUser><![CDATA[
Hakediş talebini eksiksiz hazırlayın.

Kontrol edilecek ana bilgiler:
- Hakediş no ve sözleşme no
- Proje, taşeron ve dönem
- Bu dönem iş kapsamı ve gerçekleşme oranı
- Önceki kümülatif hakediş tutarı
- Bu dönem talep edilen tutar ve KDV oranı

Zorunlu dosyalar:
- Metraj cetveli
- İmzalı hakediş kapağı
- Saha fotoğrafları veya PDF raporu
        ]]></spiffworkflow:instructionsForEndUser>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Saha</bpmn:incoming>
      <bpmn:outgoing>Flow_Saha_To_HSE</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_HSE_Kontrolu" name="İSG Kontrolü">
      <bpmn:documentation>
        İSG uzmanı saha dönemini inceler; ihlal, risk seviyesi, açık aksiyon ve kesinti bilgilerini kaydeder.
      </bpmn:documentation>
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="formJsonSchemaFilename" value="hse_kontrol.json" />
        </spiffworkflow:properties>
        <spiffworkflow:instructionsForEndUser><![CDATA[
Saha hakediş bilgilerini inceleyin:

- Hakediş no: {{ hakedis_no | default('') }}
- Sözleşme no: {{ sozlesme_no | default('') }}
- Proje: {{ proje_adi | default('') }}
- Taşeron: {{ taseron_firma | default('') }}
- Dönem: {{ donem | default('') }}
- İş kapsamı: {{ isin_kapsami | default('') }}
- İmalat gerçekleşme oranı: {{ bu_donem_imalat_orani | default('') }}%
- Önceki kümülatif hakediş: {{ onceki_hakedis_tutari | default(0) }}
- Talep edilen tutar: {{ talep_edilen_tutar | default('') }}
- Açıklama: {{ aciklama | default('') }}

İSG kontrolünde denetim tarihi, risk seviyesi, açık aksiyon sayısı, varsa kesinti tutarı ve HSE notlarını girin.
        ]]></spiffworkflow:instructionsForEndUser>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Saha_To_HSE</bpmn:incoming>
      <bpmn:outgoing>Flow_HSE_To_PM</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_PM_Onayi" name="PM Onayı">
      <bpmn:documentation>
        Proje müdürü saha ve İSG kayıtlarını değerlendirir; teknik uygunluk, metraj tutarlılığı ve revize hakediş tutarı üzerinden onay kararı verir.
      </bpmn:documentation>
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="formJsonSchemaFilename" value="pm_onay.json" />
        </spiffworkflow:properties>
        <spiffworkflow:instructionsForEndUser><![CDATA[
Saha ve İSG aşaması özeti:

- Hakediş no: {{ hakedis_no | default('') }}
- Sözleşme no: {{ sozlesme_no | default('') }}
- Proje: {{ proje_adi | default('') }}
- Taşeron: {{ taseron_firma | default('') }}
- Dönem: {{ donem | default('') }}
- İş kapsamı: {{ isin_kapsami | default('') }}
- İmalat gerçekleşme oranı: {{ bu_donem_imalat_orani | default('') }}%
- Önceki kümülatif hakediş: {{ onceki_hakedis_tutari | default(0) }}
- Talep edilen tutar: {{ talep_edilen_tutar | default('') }}
- KDV oranı: {{ kdv_orani | default('') }}%
- Saha açıklaması: {{ aciklama | default('') }}
- İSG denetim tarihi: {{ isg_denetim_tarihi | default('') }}
- İSG ihlali var mı: {{ isg_ihlal_var_mi | default(false) }}
- İSG risk seviyesi: {{ isg_risk_seviyesi | default('') }}
- Açık aksiyon sayısı: {{ acik_aksiyon_sayisi | default(0) }}
- Aksiyon kapanış durumu: {{ aksiyon_kapanis_durumu | default('') }}
- İSG kesinti tutarı: {{ kesinti_tutari | default(0) }}
- HSE notları: {{ hse_notlari | default('') }}

Teknik uygunluk, metraj uygunluğu ve PM revize hakediş tutarını girerek onay veya red kararı verin.
        ]]></spiffworkflow:instructionsForEndUser>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_HSE_To_PM</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_To_PMKarar</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_PM_Karar" name="PM Karar">
      <bpmn:documentation>
        PM onayı false ise süreç reddedilerek kapanır; true ise finans ön kontrolüne geçer.
      </bpmn:documentation>
      <bpmn:incoming>Flow_PM_To_PMKarar</bpmn:incoming>
      <bpmn:outgoing>Flow_PMKarar_To_Finans</bpmn:outgoing>
      <bpmn:outgoing>Flow_PMKarar_To_Red</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_Finans_Kontrol" name="Finans Ön Kontrol">
      <bpmn:documentation>
        Finans ekibi fatura, cari hesap, vergi borcu yoktur belgesi, kesintiler ve net ödeme tutarı üzerinden ön kontrol yapar.
      </bpmn:documentation>
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="formJsonSchemaFilename" value="finans_kontrol.json" />
        </spiffworkflow:properties>
        <spiffworkflow:instructionsForEndUser><![CDATA[
PM onayı sonrası finans ön kontrolünü tamamlayın.

- Hakediş no: {{ hakedis_no | default('') }}
- Sözleşme no: {{ sozlesme_no | default('') }}
- Proje: {{ proje_adi | default('') }}
- Taşeron: {{ taseron_firma | default('') }}
- Dönem: {{ donem | default('') }}
- Talep edilen tutar: {{ talep_edilen_tutar | default('') }}
- PM revize hakediş tutarı: {{ revize_hakedis_tutari | default('') }}
- İmalat uygun mu: {{ imalat_uygun_mu | default(true) }}
- Metraj uygun mu: {{ metraj_uygun_mu | default(true) }}
- PM gerekçe/not: {{ pm_gerekce | default('') }}
- İSG kesinti tutarı: {{ kesinti_tutari | default(0) }}

Fatura bilgilerini, cari hesap mutabakatını, yasal kesintileri, KDV tutarını, net ödeme tutarını ve önerilen ödeme tarihini girin.
        ]]></spiffworkflow:instructionsForEndUser>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PMKarar_To_Finans</bpmn:incoming>
      <bpmn:outgoing>Flow_Finans_To_FinansKarar</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Finans_Karar" name="Finans Karar">
      <bpmn:documentation>
        Finans onayı false ise süreç reddedilerek kapanır; true ise GM/CFO final onayına geçer.
      </bpmn:documentation>
      <bpmn:incoming>Flow_Finans_To_FinansKarar</bpmn:incoming>
      <bpmn:outgoing>Flow_FinansKarar_To_GM</bpmn:outgoing>
      <bpmn:outgoing>Flow_FinansKarar_To_Red</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_GM_Onayi" name="GM Final Onayı">
      <bpmn:documentation>
        Genel müdür veya CFO teknik ve finansal kontrolleri görerek final tutar, ödeme önceliği ve nihai onay kararını kaydeder.
      </bpmn:documentation>
      <bpmn:extensionElements>
        <spiffworkflow:properties>
          <spiffworkflow:property name="formJsonSchemaFilename" value="gm_onay.json" />
        </spiffworkflow:properties>
        <spiffworkflow:instructionsForEndUser><![CDATA[
Final onay öncesi özet:

- Hakediş no: {{ hakedis_no | default('') }}
- Sözleşme no: {{ sozlesme_no | default('') }}
- Proje: {{ proje_adi | default('') }}
- Taşeron: {{ taseron_firma | default('') }}
- Dönem: {{ donem | default('') }}
- Talep edilen tutar: {{ talep_edilen_tutar | default('') }}
- PM revize hakediş tutarı: {{ revize_hakedis_tutari | default('') }}
- İSG kesinti tutarı: {{ kesinti_tutari | default(0) }}
- PM gerekçe/not: {{ pm_gerekce | default('') }}
- Fatura no: {{ fatura_no | default('') }}
- Fatura tarihi: {{ fatura_tarihi | default('') }}
- Cari hesap mutabık mı: {{ cari_hesap_mutabik_mi | default(true) }}
- Stopaj / yasal kesinti: {{ stopaj_tutari | default(0) }}
- KDV tutarı: {{ kdv_tutari | default(0) }}
- Net ödeme tutarı: {{ net_odeme_tutari | default('') }}
- Önerilen ödeme tarihi: {{ onerilen_odeme_tarihi | default('') }}
- Finans notları: {{ finans_notlari | default('') }}

Final onay tutarını, ödeme önceliğini ve nihai karar gerekçesini girin.
        ]]></spiffworkflow:instructionsForEndUser>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_FinansKarar_To_GM</bpmn:incoming>
      <bpmn:outgoing>Flow_GM_To_GMKarar</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_GM_Karar" name="GM Karar">
      <bpmn:documentation>
        GM/CFO onayı true ise süreç onaylanmış olarak kapanır; false ise reddedilmiş olarak kapanır.
      </bpmn:documentation>
      <bpmn:incoming>Flow_GM_To_GMKarar</bpmn:incoming>
      <bpmn:outgoing>Flow_GMKarar_To_Onay</bpmn:outgoing>
      <bpmn:outgoing>Flow_GMKarar_To_Red</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Onaylandi" name="Onaylandı">
      <bpmn:incoming>Flow_GMKarar_To_Onay</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Reddedildi" name="Reddedildi">
      <bpmn:incoming>Flow_PMKarar_To_Red</bpmn:incoming>
      <bpmn:incoming>Flow_FinansKarar_To_Red</bpmn:incoming>
      <bpmn:incoming>Flow_GMKarar_To_Red</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_Saha" sourceRef="StartEvent_Baslangic" targetRef="Task_Saha_Hakedis_Girisi" />
    <bpmn:sequenceFlow id="Flow_Saha_To_HSE" sourceRef="Task_Saha_Hakedis_Girisi" targetRef="Task_HSE_Kontrolu" />
    <bpmn:sequenceFlow id="Flow_HSE_To_PM" sourceRef="Task_HSE_Kontrolu" targetRef="Task_PM_Onayi" />
    <bpmn:sequenceFlow id="Flow_PM_To_PMKarar" sourceRef="Task_PM_Onayi" targetRef="Gateway_PM_Karar" />
    <bpmn:sequenceFlow id="Flow_PMKarar_To_Finans" name="PM Onay" sourceRef="Gateway_PM_Karar" targetRef="Task_Finans_Kontrol">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">pm_onay_durum == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PMKarar_To_Red" name="PM Red" sourceRef="Gateway_PM_Karar" targetRef="EndEvent_Reddedildi">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">pm_onay_durum == False</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Finans_To_FinansKarar" sourceRef="Task_Finans_Kontrol" targetRef="Gateway_Finans_Karar" />
    <bpmn:sequenceFlow id="Flow_FinansKarar_To_GM" name="Finans Onay" sourceRef="Gateway_Finans_Karar" targetRef="Task_GM_Onayi">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">finans_onay_durum == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_FinansKarar_To_Red" name="Finans Red" sourceRef="Gateway_Finans_Karar" targetRef="EndEvent_Reddedildi">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">finans_onay_durum == False</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GM_To_GMKarar" sourceRef="Task_GM_Onayi" targetRef="Gateway_GM_Karar" />
    <bpmn:sequenceFlow id="Flow_GMKarar_To_Onay" name="GM Onay" sourceRef="Gateway_GM_Karar" targetRef="EndEvent_Onaylandi">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">gm_onay_durum == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GMKarar_To_Red" name="GM Red" sourceRef="Gateway_GM_Karar" targetRef="EndEvent_Reddedildi">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">gm_onay_durum == False</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_insaat_hakedis_sureci">
    <bpmndi:BPMNPlane id="BPMNPlane_insaat_hakedis_sureci" bpmnElement="insaat_hakedis_sureci">
      <bpmndi:BPMNShape id="Shape_StartEvent_Baslangic" bpmnElement="StartEvent_Baslangic">
        <dc:Bounds x="100" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Saha_Hakedis_Girisi" bpmnElement="Task_Saha_Hakedis_Girisi">
        <dc:Bounds x="180" y="220" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_HSE_Kontrolu" bpmnElement="Task_HSE_Kontrolu">
        <dc:Bounds x="400" y="220" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_PM_Onayi" bpmnElement="Task_PM_Onayi">
        <dc:Bounds x="620" y="220" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_PM_Karar" bpmnElement="Gateway_PM_Karar" isMarkerVisible="true">
        <dc:Bounds x="835" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Finans_Kontrol" bpmnElement="Task_Finans_Kontrol">
        <dc:Bounds x="940" y="220" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Finans_Karar" bpmnElement="Gateway_Finans_Karar" isMarkerVisible="true">
        <dc:Bounds x="1155" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_GM_Onayi" bpmnElement="Task_GM_Onayi">
        <dc:Bounds x="1260" y="220" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_GM_Karar" bpmnElement="Gateway_GM_Karar" isMarkerVisible="true">
        <dc:Bounds x="1475" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Onaylandi" bpmnElement="EndEvent_Onaylandi">
        <dc:Bounds x="1585" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Reddedildi" bpmnElement="EndEvent_Reddedildi">
        <dc:Bounds x="1585" y="390" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_Saha" bpmnElement="Flow_Start_To_Saha">
        <di:waypoint x="136" y="260" />
        <di:waypoint x="180" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Saha_To_HSE" bpmnElement="Flow_Saha_To_HSE">
        <di:waypoint x="350" y="260" />
        <di:waypoint x="400" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_HSE_To_PM" bpmnElement="Flow_HSE_To_PM">
        <di:waypoint x="570" y="260" />
        <di:waypoint x="620" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_PM_To_PMKarar" bpmnElement="Flow_PM_To_PMKarar">
        <di:waypoint x="790" y="260" />
        <di:waypoint x="835" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_PMKarar_To_Finans" bpmnElement="Flow_PMKarar_To_Finans">
        <di:waypoint x="885" y="260" />
        <di:waypoint x="940" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_PMKarar_To_Red" bpmnElement="Flow_PMKarar_To_Red">
        <di:waypoint x="860" y="285" />
        <di:waypoint x="860" y="408" />
        <di:waypoint x="1585" y="408" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Finans_To_FinansKarar" bpmnElement="Flow_Finans_To_FinansKarar">
        <di:waypoint x="1110" y="260" />
        <di:waypoint x="1155" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_FinansKarar_To_GM" bpmnElement="Flow_FinansKarar_To_GM">
        <di:waypoint x="1205" y="260" />
        <di:waypoint x="1260" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_FinansKarar_To_Red" bpmnElement="Flow_FinansKarar_To_Red">
        <di:waypoint x="1180" y="285" />
        <di:waypoint x="1180" y="408" />
        <di:waypoint x="1585" y="408" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_GM_To_GMKarar" bpmnElement="Flow_GM_To_GMKarar">
        <di:waypoint x="1430" y="260" />
        <di:waypoint x="1475" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_GMKarar_To_Onay" bpmnElement="Flow_GMKarar_To_Onay">
        <di:waypoint x="1525" y="260" />
        <di:waypoint x="1585" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_GMKarar_To_Red" bpmnElement="Flow_GMKarar_To_Red">
        <di:waypoint x="1500" y="285" />
        <di:waypoint x="1500" y="408" />
        <di:waypoint x="1585" y="408" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
