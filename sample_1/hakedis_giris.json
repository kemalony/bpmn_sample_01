{
  "title": "Saha Hakediş Girişi",
  "description": "Saha mühendisi tarafından hakediş talebinin ve destekleyici dosyaların girilmesi.",
  "type": "object",
  "properties": {
    "hakedis_no": {
      "type": "string",
      "title": "Hakediş No",
      "description": "Örn. HKD-2026-005"
    },
    "sozlesme_no": {
      "type": "string",
      "title": "Sözleşme No"
    },
    "proje_adi": {
      "type": "string",
      "title": "Proje Adı",
      "description": "Proje bilgisi önceki ekranda girilir.",
      "readOnly": true
    },
    "taseron_firma": {
      "type": "string",
      "title": "Taşeron Firma",
      "description": "Taşeron bilgisi önceki ekranda girilir.",
      "readOnly": true
    },
    "donem": {
      "type": "string",
      "title": "Dönem",
      "description": "MM/YYYY formatında girin.",
      "pattern": "^(0[1-9]|1[0-2])/[0-9]{4}$",
      "examples": [
        "05/2026"
      ]
    },
    "isin_kapsami": {
      "type": "string",
      "title": "Bu Dönem Yapılan İşin Kapsamı",
      "description": "İmalat kalemlerini, mahal/blok bilgilerini ve gerçekleşen ana işleri özetleyin.",
      "ui:widget": "textarea"
    },
    "onceki_hakedis_tutari": {
      "type": "number",
      "title": "Önceki Kümülatif Hakediş Tutarı (TL)",
      "minimum": 0,
      "default": 0
    },
    "talep_edilen_tutar": {
      "type": "number",
      "title": "Talep Edilen Tutar (TL)",
      "description": "Bu dönem için KDV hariç brüt hakediş tutarı.",
      "minimum": 0
    },
    "bu_donem_imalat_orani": {
      "type": "number",
      "title": "Bu Dönem İmalat Gerçekleşme Oranı (%)",
      "minimum": 0,
      "maximum": 100
    },
    "kdv_orani": {
      "type": "number",
      "title": "KDV Oranı (%)",
      "enum": [
        0,
        1,
        10,
        20
      ],
      "default": 20
    },
    "aciklama": {
      "type": "string",
      "title": "Açıklama",
      "ui:widget": "textarea"
    },
    "metraj_cetveli": {
      "type": "string",
      "title": "Metraj Cetveli",
      "description": "Excel formatında metraj cetveli yükleyin",
      "format": "data-url",
      "contentEncoding": "base64",
      "ui:widget": "file"
    },
    "imzali_hakedis_kapagi": {
      "type": "string",
      "title": "İmzalı Hakediş Kapağı",
      "description": "Taşeron tarafından imzalanmış hakediş kapak sayfası",
      "format": "data-url",
      "contentEncoding": "base64",
      "ui:widget": "file"
    },
    "saha_fotograflari": {
      "type": "string",
      "title": "Saha Fotoğrafları / PDF Raporu",
      "description": "Yapılan imalatın fotoğrafları veya PDF raporu",
      "format": "data-url",
      "contentEncoding": "base64",
      "ui:widget": "file"
    },
    "ek_belgeler": {
      "type": "string",
      "title": "Ek Belgeler",
      "description": "Varsa ataşman, tutanak, revizyon veya teslim dokümanı",
      "format": "data-url",
      "contentEncoding": "base64",
      "ui:widget": "file"
    }
  },
  "required": [
    "hakedis_no",
    "sozlesme_no",
    "proje_adi",
    "taseron_firma",
    "donem",
    "isin_kapsami",
    "onceki_hakedis_tutari",
    "talep_edilen_tutar",
    "bu_donem_imalat_orani",
    "kdv_orani",
    "aciklama",
    "metraj_cetveli",
    "imzali_hakedis_kapagi",
    "saha_fotograflari"
  ]
}
