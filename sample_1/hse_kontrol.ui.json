{
  "ui:classNames": "modern-process-form hse-review-form",
  "ui:field": "LayoutGridField",
  "ui:layoutGrid": {
    "ui:row": {
      "spacing": 2,
      "sx": {
        "p": 2.5,
        "borderRadius": "18px",
        "background": "linear-gradient(135deg, #111827 0%, #172033 55%, #0f172a 100%)",
        "border": "1px solid rgba(148, 163, 184, 0.24)",
        "boxShadow": "0 22px 55px rgba(2, 6, 23, 0.28)",
        "& .MuiFormControl-root, & .MuiTextField-root": {
          "width": "100%"
        },
        "& .MuiInputBase-root": {
          "backgroundColor": "rgba(255, 255, 255, 0.08)",
          "borderRadius": "12px",
          "color": "#f8fafc"
        },
        "& input, & textarea": {
          "color": "#f8fafc"
        },
        "& .MuiInputLabel-root, & .MuiFormLabel-root, & .MuiTypography-root": {
          "color": "#e2e8f0"
        },
        "& .MuiFormHelperText-root": {
          "color": "#94a3b8"
        },
        "& .MuiOutlinedInput-notchedOutline": {
          "borderColor": "rgba(148, 163, 184, 0.38)"
        },
        "& .Mui-focused .MuiOutlinedInput-notchedOutline": {
          "borderColor": "#22c55e"
        },
        "& .MuiRadio-root, & .MuiCheckbox-root, & .MuiSvgIcon-root": {
          "color": "#86efac"
        },
        "& .MuiFormControlLabel-label": {
          "color": "#e5e7eb"
        }
      },
      "children": [
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "isg_denetim_tarihi"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "isg_ihlal_var_mi"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "isg_risk_seviyesi"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "acik_aksiyon_sayisi"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "aksiyon_kapanis_durumu"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "kesinti_tutari"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 5
            },
            "children": [
              "isg_raporu"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 7
            },
            "children": [
              "hse_notlari"
            ]
          }
        }
      ]
    }
  },
  "ui:order": [
    "isg_denetim_tarihi",
    "isg_ihlal_var_mi",
    "isg_risk_seviyesi",
    "acik_aksiyon_sayisi",
    "aksiyon_kapanis_durumu",
    "kesinti_tutari",
    "isg_raporu",
    "hse_notlari"
  ],
  "isg_denetim_tarihi": {
    "ui:widget": "date"
  },
  "isg_ihlal_var_mi": {
    "ui:widget": "checkbox",
    "ui:help": "İş güvenliği ihlali tespit edildiyse işaretleyin."
  },
  "isg_risk_seviyesi": {
    "ui:widget": "radio",
    "ui:options": {
      "inline": true
    }
  },
  "acik_aksiyon_sayisi": {
    "ui:placeholder": "0"
  },
  "aksiyon_kapanis_durumu": {
    "ui:widget": "radio",
    "ui:options": {
      "inline": true
    }
  },
  "kesinti_tutari": {
    "ui:placeholder": "0"
  },
  "isg_raporu": {
    "ui:widget": "file",
    "ui:options": {
      "accept": ".pdf"
    }
  },
  "hse_notlari": {
    "ui:placeholder": "Denetim bulguları, açık aksiyonlar ve ödeme kesintisine konu olabilecek notlar.",
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 5
    }
  }
}
