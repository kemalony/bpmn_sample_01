{
  "ui:classNames": "modern-process-form executive-approval-form",
  "ui:field": "LayoutGridField",
  "ui:layoutGrid": {
    "ui:row": {
      "spacing": 2,
      "sx": {
        "p": 2.5,
        "borderRadius": "18px",
        "background": "linear-gradient(135deg, #0f172a 0%, #1f2937 52%, #111827 100%)",
        "border": "1px solid rgba(148, 163, 184, 0.24)",
        "boxShadow": "0 22px 55px rgba(2, 6, 23, 0.28)",
        "& .MuiFormControl-root, & .MuiTextField-root": {
          "width": "100%"
        },
        "& .MuiInputBase-root": {
          "backgroundColor": "rgba(255, 255, 255, 0.08)",
          "borderRadius": "12px",
          "color": "#f8fafc"
        },
        "& input, & textarea": {
          "color": "#f8fafc"
        },
        "& .MuiInputLabel-root, & .MuiFormLabel-root, & .MuiTypography-root": {
          "color": "#e2e8f0"
        },
        "& .MuiFormHelperText-root": {
          "color": "#94a3b8"
        },
        "& .MuiOutlinedInput-notchedOutline": {
          "borderColor": "rgba(148, 163, 184, 0.38)"
        },
        "& .Mui-focused .MuiOutlinedInput-notchedOutline": {
          "borderColor": "#fbbf24"
        },
        "& .MuiRadio-root, & .MuiCheckbox-root, & .MuiSvgIcon-root": {
          "color": "#fde68a"
        },
        "& .MuiFormControlLabel-label": {
          "color": "#e5e7eb"
        }
      },
      "children": [
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "final_onay_tutari"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "odeme_onceligi"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 4
            },
            "children": [
              "gm_onay_durum"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 6
            },
            "children": [
              "gm_gerekce"
            ]
          }
        },
        {
          "ui:col": {
            "size": {
              "xs": 12,
              "md": 6
            },
            "children": [
              "yonetim_notu"
            ]
          }
        }
      ]
    }
  },
  "ui:order": [
    "final_onay_tutari",
    "odeme_onceligi",
    "gm_onay_durum",
    "gm_gerekce",
    "yonetim_notu"
  ],
  "final_onay_tutari": {
    "ui:placeholder": "Final ödeme tutarı"
  },
  "odeme_onceligi": {
    "ui:widget": "radio",
    "ui:options": {
      "inline": true
    }
  },
  "gm_onay_durum": {
    "ui:widget": "checkbox",
    "ui:help": "İşaretli ise süreç onaylanır; kapalı ise süreç reddedilir."
  },
  "gm_gerekce": {
    "ui:placeholder": "Nihai karar gerekçesi.",
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 4
    }
  },
  "yonetim_notu": {
    "ui:placeholder": "Ödeme zamanı, öncelik veya sözleşmesel kayıt için yönetim notu.",
    "ui:widget": "textarea",
    "ui:options": {
      "rows": 4
    }
  }
}
