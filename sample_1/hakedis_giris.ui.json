  "imzali_hakedis_kapagi": {
    "ui:widget": "file",
    "ui:options": {
      "accept": ".pdf,.jpg,.jpeg,.png"
    }
  },
  "saha_fotograflari": {
    "ui:widget": "file",
    "ui:options": {
      "accept": ".pdf,.jpg,.jpeg,.png"
    }
  },
  "ek_belgeler": {
    "ui:widget": "file",
    "ui:options": {
      "accept": ".pdf,.xls,.xlsx,.doc,.docx,.jpg,.jpeg,.png"
